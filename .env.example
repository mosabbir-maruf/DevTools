# Telegram contact-form delivery (server-side only — never exposed to the browser).
# Set these in your Vercel project: Settings → Environment Variables.
#
# 1. Create a bot with @BotFather and copy the token.
# 2. Get your chat id (message @userinfobot, or use the getUpdates API after
#    sending your bot a message).
TELEGRAM_BOT_TOKEN=123456789:your-bot-token-here
TELEGRAM_CHAT_ID=your-numeric-chat-id-here
